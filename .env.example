PORT=5000
MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/plumedica
JWT_SECRET=replace-with-strong-secret
JWT_EXPIRES_IN=7d
ADMIN_NAME=Super Admin
ADMIN_EMAIL=admin@plumedica.com
ADMIN_PASSWORD=ChangeThisStrongPassword
ADMIN_ROLE=superadmin

# Password reset security and limits
PASSWORD_RESET_TOKEN_PEPPER=replace-with-strong-pepper
PASSWORD_RESET_TOKEN_TTL_MINUTES=15
FORGOT_PASSWORD_WINDOW_MINUTES=15
FORGOT_PASSWORD_MAX_ATTEMPTS=5

# App and notification channels
APP_NAME=PluMedica
PASSWORD_RESET_REQUIRE_DELIVERY=false

# SendGrid (email reset delivery)
SENDGRID_API_KEY=SG.your-sendgrid-api-key
APPROVAL_FROM_EMAIL=harika.nagaraju@plumedica.com
ENTITY_STATUS_EMAIL_MAX_RETRIES=1

# Twilio (SMS reset delivery)
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_FROM_NUMBER=+15555555555
